<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup/transfer rules.
  Excludes everything from cloud backup and device-to-device transfer
  to prevent auth tokens, FCM tokens, and user data from being copied
  off the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
