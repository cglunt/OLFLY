# Copy this file to .env and fill in values

# Database
DATABASE_URL=

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=Olfly <noreply@olfly.app>

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (optional — only needed for web checkout; not used for Android in-app purchases)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# RevenueCat — in-app purchases (Google Play Billing / App Store)
# Get the platform public API keys from: https://app.revenuecat.com → Project → API keys
# (VITE_ keys are baked into the web bundle at build time — rebuild after changing)
VITE_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Shared secret for the RevenueCat webhook (set when you add the webhook in RC dashboard).
# REQUIRED in production — the webhook rejects all events until this is set.
REVENUECAT_WEBHOOK_SECRET=

# Web Push / VAPID keys
# Generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@olfly.com
